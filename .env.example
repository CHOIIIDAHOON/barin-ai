# Working copy of the repo the agent should see (clone your app here on the server).
CURSOR_PROJECT_DIR=/var/cursor-project

# Full path recommended in systemd (run: which cursor).
CURSOR_CLI_PATH=cursor

# Cursor model (cursor agent --list-models). Default in config: composer-2-fast.
# 응답 속도 우선(채팅만): gemini-3-flash 또는 gpt-5.4-nano-medium + 아래 ask 모드 권장
# CURSOR_MODEL=composer-2-fast
# Read-only Q&A (도구/편집 최소화 → 체감 지연 감소): CURSOR_AGENT_MODE=ask
# CURSOR_AGENT_MODE=

# How long to wait for one agent run (seconds).
AGENT_TIMEOUT_SEC=600

# Set on the server for Cursor headless auth (Dashboard → API keys / CLI).
CURSOR_API_KEY=

# Optional: if set, clients must send: Authorization: Bearer <same value>
CHAT_API_SECRET=

# Flutter 웹이 158.x 등 원격 API를 부를 때 브라우저 CORS. 실제 앱 Origin을 넣으세요 (쉼표 구분).
# 예: CORS_ALLOW_ORIGINS=http://localhost:5555,https://yourapp.web.app
# 빠른 내부 테스트만: CORS_ALLOW_ALL=true (allow_credentials 끔)
CORS_ALLOW_ORIGINS=
# CORS_ENABLE_LOCALHOST_REGEX=false
# CORS_ALLOW_ALL=false
# Nginx가 CORS 처리할 때( deploy/nginx-snippet.conf ): USE_NGINX_CORS=true
# USE_NGINX_CORS=false

# Cursor CLI 없이 POST /chat 즉시 응답 (연동 테스트용). 운영에서는 false.
# MOCK_AGENT=true
